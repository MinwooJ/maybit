{
  "name": "maybit",
  "version": "0.0.0",
  "private": true,
  "description": "Upbit short-term auto-trading bot with dashboard",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:bot": "pnpm --filter @maybit/bot dev",
    "dev:dashboard": "pnpm --filter @maybit/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
